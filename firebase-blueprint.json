{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the NETSOLAR DTR system.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "employee", "intern"],
          "description": "The user's role in the system."
        },
        "department": {
          "type": "string",
          "description": "The department the user belongs to."
        },
        "phone": {
          "type": "string",
          "description": "The telephone number of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created."
        }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "DTRLog": {
      "title": "DTR Log",
      "description": "A daily time record entry.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this log."
        },
        "date": {
          "type": "string",
          "description": "The date of the log in YYYY-MM-DD format."
        },
        "timeIn": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user clocked in."
        },
        "timeOut": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user clocked out."
        },
        "totalHours": {
          "type": "number",
          "description": "The total hours worked."
        },
        "status": {
          "type": "string",
          "enum": ["on-time", "late", "absent", "incomplete"],
          "description": "The status of the DTR."
        },
        "activities": {
          "type": "string",
          "description": "Tasks done per day."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the log was created."
        }
      },
      "required": ["userId", "date", "timeIn", "createdAt"]
    },
    "Department": {
      "title": "Department",
      "description": "A department in the company.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the department."
        },
        "description": {
          "type": "string",
          "description": "A description of the department."
        }
      },
      "required": ["name"]
    },
    "Adjustment": {
      "title": "Adjustment",
      "description": "A request for a time correction or overtime.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who requested the adjustment."
        },
        "date": {
          "type": "string",
          "description": "The date of the adjustment in YYYY-MM-DD format."
        },
        "type": {
          "type": "string",
          "enum": ["correction", "overtime"],
          "description": "The type of adjustment."
        },
        "requestedTimeIn": {
          "type": "string",
          "description": "The newly requested time in."
        },
        "requestedTimeOut": {
          "type": "string",
          "description": "The newly requested time out."
        },
        "reason": {
          "type": "string",
          "description": "The reason for the adjustment."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "The status of the adjustment request."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the request was created."
        }
      },
      "required": ["userId", "date", "type", "requestedTimeIn", "requestedTimeOut", "reason", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "A record of significant actions performed in the system.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who performed the action."
        },
        "userName": {
          "type": "string",
          "description": "The name of the user who performed the action."
        },
        "action": {
          "type": "string",
          "description": "The type of action performed (e.g., 'update_role', 'create_user', 'modify_dtr')."
        },
        "details": {
          "type": "string",
          "description": "Human-readable details of the action."
        },
        "targetId": {
          "type": "string",
          "description": "The ID of the affected resource (user ID, log ID, etc.)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the action occurred."
        }
      },
      "required": ["userId", "userName", "action", "details", "createdAt"]
    }
  },
  "firestore": {
    "/audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Stores audit logs."
    },
    "/adjustments/{adjustmentId}": {
      "schema": { "$ref": "#/entities/Adjustment" },
      "description": "Stores adjustment requests."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/dtr_logs/{logId}": {
      "schema": { "$ref": "#/entities/DTRLog" },
      "description": "Stores daily time records."
    },
    "/departments/{deptId}": {
      "schema": { "$ref": "#/entities/Department" },
      "description": "Stores department information."
    }
  }
}
