{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "intern", "admin"] },
        "department": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "targetHours": { "type": "number" },
        "startDate": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "username", "name", "email", "role", "createdAt", "status"]
    },
    "Username": {
      "title": "Username",
      "description": "Username claim document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    },
    "DTRLog": {
      "title": "DTR Log",
      "description": "Daily Time Record Log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "timeIn": { "type": "string" },
        "timeOut": { "type": "string" },
        "totalHours": { "type": "number" },
        "status": { "type": "string", "enum": ["late", "on-time"] },
        "activities": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "date", "timeIn", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Company announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "content", "authorId", "authorName", "createdAt"]
    },
    "Adjustment": {
      "title": "Adjustment",
      "description": "Adjustment Request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["correction", "overtime"] },
        "requestedTimeIn": { "type": "string" },
        "requestedTimeOut": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "date", "type", "requestedTimeIn", "requestedTimeOut", "reason", "status", "createdAt"]
    },
    "LeaveRequest": {
      "title": "LeaveRequest",
      "description": "Leave Request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "type": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "startDate", "endDate", "type", "reason", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Audit Log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "targetId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "userName", "action", "details", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "usernames/{username}": {
      "schema": { "$ref": "#/entities/Username" },
      "description": "Username claims"
    },
    "dtr_logs/{logId}": {
      "schema": { "$ref": "#/entities/DTRLog" },
      "description": "DTR Logs"
    },
    "announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Announcements"
    },
    "adjustments/{adjustmentId}": {
      "schema": { "$ref": "#/entities/Adjustment" },
      "description": "Adjustment requests"
    },
    "leave_requests/{requestId}": {
      "schema": { "$ref": "#/entities/LeaveRequest" },
      "description": "Leave requests"
    },
    "audit_logs/{logId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Audit logs"
    }
  }
}
