rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null && request.auth.uid != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'name', 'email', 'role', 'createdAt', 'status'])
        && data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.username is string && data.username.size() >= 3 && data.username.size() <= 30
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.role is string && data.role in ['employee', 'intern', 'admin']
        && data.status is string && data.status in ['active', 'inactive']
        && data.createdAt is string && data.createdAt.size() <= 50
        && (!data.keys().hasAny(['phone']) || (data.phone is string && data.phone.size() <= 20))
        && (!data.keys().hasAny(['department']) || (data.department is string && data.department.size() <= 50))
        && (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 200))
        && (!data.keys().hasAny(['targetHours']) || data.targetHours is number)
        && (!data.keys().hasAny(['startDate']) || (data.startDate is string && data.startDate.size() <= 50));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && userId == request.auth.uid
        && isValidUser(incoming())
        && (incoming().role in ['employee', 'intern']) // only admin can override this, but admins are created manually or initially? Wait, a user can't create themselves as admin
        && (incoming().status == 'active');
        
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          userId == request.auth.uid 
          && isValidUser(incoming())
          && incoming().role == existing().role
          && incoming().status == existing().status
          && incoming().uid == existing().uid
          && incoming().createdAt == existing().createdAt
          && (!existing().keys().hasAny(['targetHours']) || incoming().targetHours == existing().targetHours) // users cannot modify targethours
        )
      );
      allow delete: if isAdmin();
    }

    match /usernames/{username} {
      allow get, list: if true;
      allow create: if isSignedIn()
        && incoming().keys().hasAll(['uid'])
        && incoming().uid is string
        && incoming().uid == request.auth.uid;
      allow update: if false; // Usernames are immutable
      allow delete: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid);
    }

    function isValidDTRLog(data) {
      return data.keys().hasAll(['userId', 'date', 'timeIn', 'createdAt'])
        && data.userId is string && data.userId == request.auth.uid
        && data.date is string && data.date.size() <= 50
        && data.timeIn is string && data.timeIn.size() <= 50
        && data.createdAt is string && data.createdAt.size() <= 50
        && (!data.keys().hasAny(['timeOut']) || (data.timeOut is string && data.timeOut.size() <= 50))
        && (!data.keys().hasAny(['totalHours']) || (data.totalHours is number && data.totalHours <= 24))
        && (!data.keys().hasAny(['status']) || (data.status is string && data.status in ['late', 'on-time']))
        && (!data.keys().hasAny(['activities']) || (data.activities is string && data.activities.size() <= 10000))
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 10000));
    }

    match /dtr_logs/{logId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() 
        && isValidId(logId)
        && isValidDTRLog(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          existing().userId == request.auth.uid
          && isValidDTRLog(incoming())
          && incoming().userId == existing().userId
          && incoming().date == existing().date
          && incoming().timeIn == existing().timeIn
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['timeOut', 'totalHours', 'activities', 'notes'])
        )
      );
      allow delete: if isAdmin();
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'createdAt'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.content is string && data.content.size() > 0 && data.content.size() <= 10000
        && data.authorId is string && data.authorId == request.auth.uid
        && data.authorName is string && data.authorName.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /announcements/{announcementId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() && isValidId(announcementId) && isValidAnnouncement(incoming());
      allow update: if isAdmin() && isValidAnnouncement(incoming());
      allow delete: if isAdmin();
    }

    function isValidAdjustment(data) {
      return data.keys().hasAll(['userId', 'date', 'type', 'requestedTimeIn', 'requestedTimeOut', 'reason', 'status', 'createdAt'])
        && data.userId is string && data.userId == request.auth.uid
        && data.date is string && data.date.size() <= 50
        && data.type is string && data.type in ['correction', 'overtime']
        && data.requestedTimeIn is string && data.requestedTimeIn.size() <= 50
        && data.requestedTimeOut is string && data.requestedTimeOut.size() <= 50
        && data.reason is string && data.reason.size() <= 2000
        && data.status is string && data.status in ['pending', 'approved', 'rejected']
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /adjustments/{adjustmentId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(adjustmentId) && isValidAdjustment(incoming()) && incoming().status == 'pending';
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          existing().userId == request.auth.uid
          && isValidAdjustment(incoming())
          && existing().status == 'pending'
          && incoming().status == 'pending' // users can't approve their own adjustment
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
        )
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid && existing().status == 'pending');
    }

    function isValidLeaveRequest(data) {
      return data.keys().hasAll(['userId', 'startDate', 'endDate', 'type', 'reason', 'status', 'createdAt'])
        && data.userId is string && data.userId == request.auth.uid
        && data.startDate is string && data.startDate.size() <= 50
        && data.endDate is string && data.endDate.size() <= 50
        && data.type is string && data.type.size() <= 100
        && data.reason is string && data.reason.size() <= 2000
        && data.status is string && data.status in ['pending', 'approved', 'rejected']
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /leave_requests/{requestId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(requestId) && isValidLeaveRequest(incoming()) && incoming().status == 'pending';
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          existing().userId == request.auth.uid
          && isValidLeaveRequest(incoming())
          && existing().status == 'pending'
          && incoming().status == 'pending'
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
        )
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid && existing().status == 'pending');
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['userId', 'userName', 'action', 'details', 'createdAt'])
        && data.userId is string && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.action is string && data.action.size() <= 100
        && data.details is string && data.details.size() <= 10000
        && data.createdAt is string && data.createdAt.size() <= 50
        && (!data.keys().hasAny(['targetId']) || (data.targetId is string && data.targetId.size() <= 128));
    }

    match /audit_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && isValidId(logId) && isValidAuditLog(incoming());
      allow update, delete: if false; // Immutable
    }
  }
}
